# Server Port
PORT=5000

# PostgreSQL Connection String
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nqt_db

# Secret key for signing JWT tokens
JWT_SECRET=your_jwt_secret_key_change_in_production

# Admin Account Email Address (protected admin panel route VITE_ADMIN_EMAIL on frontend matches this)
ADMIN_EMAIL=admin@nqt.com
VITE_ADMIN_EMAIL=admin@nqt.com

# AI Tutor API Credentials (local development values)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
